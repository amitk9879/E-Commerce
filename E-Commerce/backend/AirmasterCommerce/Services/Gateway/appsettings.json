{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" },
        "RateLimiterPolicy": "StrictSecurePolicy"
      },
      "catalog-route": {
        "ClusterId": "catalog-cluster",
        "Match": { "Path": "/api/catalog/{**catch-all}" },
        "RateLimiterPolicy": "StandardReadPolicy"
      },
      "ordering-route": {
        "ClusterId": "ordering-cluster",
        "Match": { "Path": "/api/orders/{**catch-all}" },
        "RateLimiterPolicy": "StrictSecurePolicy"
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": { "Path": "/hub/notifications/{**catch-all}" }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": { "Address": "https://localhost:7259" }
        }
      },
      "catalog-cluster": {
        "Destinations": {
          "destination1": { "Address": "https://localhost:7141" }
        }
      },
      "ordering-cluster": {
        "Destinations": {
          "destination1": { "Address": "https://localhost:7247" }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "destination1": { "Address": "https://localhost:7078" }
        }
      }
    }
  }
}